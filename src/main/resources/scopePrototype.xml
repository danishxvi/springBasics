<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
       http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!--
        scope="prototype"

        Prototype means Spring DOES NOT create the object during
        container initialization.

        Instead, Spring only stores the bean definition.

        Whenever getBean() is called,
        Spring creates a completely new object,
        injects dependencies,
        and returns that newly created object.

        Therefore,

        getBean() -> New Object
        getBean() -> New Object
        getBean() -> New Object

        Every call creates a different instance.
    -->

    <bean id="developer"
          class="com.danish.xvi.springbasics.scope.prototype.Developer"
          scope="prototype"/>

</beans>